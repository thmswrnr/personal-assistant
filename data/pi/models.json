{
  // ── Your model provider ───────────────────────────────────────────────────────────────────
  // Core is model-agnostic. To point it at ANY OpenAI-compatible API, edit just three things:
  //   1. baseUrl below            — your endpoint (this file)
  //   2. LLM_API_KEY in .env      — your key (env, so it stays out of version control)
  //   3. defaultModel in settings.json + the model id(s) listed here
  //
  // "openai-completions" is the OpenAI chat-completions wire format — spoken by Alan, OpenAI,
  // Groq, OpenRouter, Together, vLLM, LM Studio, llama.cpp, and most others. apiKey supports
  // $ENV interpolation ($LLM_API_KEY here); baseUrl is a literal string. If you self-host a
  // model (e.g. examples/local-models/), set baseUrl to its host:port and any LLM_API_KEY value
  // (a local server ignores it). For pi's BUILT-IN providers (anthropic/openai/gemini, etc.)
  // you don't need an entry here at all — set their standard key env var and reference the model
  // as "<provider>/<id>" in settings.json.
  //
  // Shipped default: Comma-Soft Alan's OpenAI-compatible endpoint. Change it to your own.
  "providers": {
    "api": {
      "baseUrl": "https://dev.alan.de/api/v1/oai",
      "api": "openai-completions",
      "apiKey": "$LLM_API_KEY",
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": false
      },
      "models": [
        {
          "id": "comma-soft/gemma4-31b-instant",
          "name": "Main model — instant (no reasoning)",
          "reasoning": false,
          "input": ["text", "image"],
          "contextWindow": 200000,
          "maxTokens": 32768,
          "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
        },
        {
          "id": "comma-soft/gemma4-31b",
          "name": "Main model — thinking",
          "reasoning": true,
          "input": ["text", "image"],
          "contextWindow": 200000,
          "maxTokens": 32768,
          "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
        }
      ]
    }
  }
}
