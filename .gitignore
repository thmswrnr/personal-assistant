# Local planning / scratch docs (IDEA, PLAN, QUESTIONS_TODO)
planning/

# Secrets & environment
.env

# Claude Code local settings
.claude/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp

# Node (if running tooling locally)
node_modules/
npm-debug.log*

# Large model weights — keep the folder, ignore the files
data/models/*
!data/models/.gitkeep

# User files & secrets — keep the folders, ignore the contents
data/storage/*
!data/storage/.gitkeep
data/secrets/*
!data/secrets/.gitkeep

# pi config dir: ignore everything pi generates at runtime (sessions, auth, settings,
# trust, downloaded bin/, rolling context, the skills mountpoint) and track ONLY the
# config we author. Whitelist approach, so new pi runtime files are ignored by default.
data/pi/*
!data/pi/models.json
!data/pi/SYSTEM.md
# Track our own extension source, but not any runtime files pi drops in extensions/
!data/pi/extensions/
data/pi/extensions/*
!data/pi/extensions/context-saver.mjs
!data/pi/extensions/memory.mjs
# Track our custom subagent definitions (they inherit Core's model unless they pin one)
!data/pi/agents/
!data/pi/agents/*.md
