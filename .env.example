# Copy to .env (which is git-ignored) and fill in as needed.
#
# Local-only use needs NOTHING here — the local llama.cpp model is configured in
# data/pi/models.json and requires no key.
#
# These are only needed if you switch pi to a commercial provider (see README →
# "Adding or switching a model"). Uncomment and set the ones you use. Confirm the exact
# variable name your provider expects via `docker exec core_harness pi --list-models`
# and the pi providers docs.

# Google Gemini
# GEMINI_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# Anthropic
# ANTHROPIC_API_KEY=

# SearXNG (websearch skill): secret key for the local, internal-only instance.
# Generate one with:  openssl rand -hex 32
SEARXNG_SECRET=

# Telegram (OPTIONAL — phone bridge + `notify` skill; Core runs fine without it).
# 1. Create a bot with @BotFather in Telegram, paste its token here.
# 2. Message your bot once, then start the bridge (docker compose --profile telegram up -d bot)
#    and read `docker logs core_bot` — it prints your chat id. Put it below and restart.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
