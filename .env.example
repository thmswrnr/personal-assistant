# Copy to .env (which is git-ignored) and fill in as needed.
#
# ── Model API key ──────────────────────────────────────────────────────────────────────────
# Core talks to an OpenAI-compatible API. The endpoint and model are set in data/pi/models.json
# (the `api` provider) and data/pi/settings.json; only the KEY lives here, so it stays out of
# version control. Set LLM_API_KEY to your provider's key.
# (Self-hosting a model via examples/local-models/? Any value works — a local server ignores it.)
LLM_API_KEY=

# Prefer one of pi's BUILT-IN providers (anthropic / openai / gemini / …) instead of the generic
# `api` entry in models.json? Set its standard key below and reference the model as
# "<provider>/<id>" in data/pi/settings.json. Confirm exact names with:
#   docker exec core_harness pi --list-models
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# SearXNG (websearch skill): secret key for the local, internal-only instance.
# Generate one with:  openssl rand -hex 32
SEARXNG_SECRET=

# Telegram (OPTIONAL — used by the `notify` skill to send you one-way pings; Core runs fine
# without it). There is no interactive bot — this is outbound-only.
# 1. Create a bot with @BotFather in Telegram, paste its token here.
# 2. Message your bot once, then read your chat id from:
#    curl -s "https://api.telegram.org/bot<TOKEN>/getUpdates" | grep -o '"chat":{"id":[0-9-]*'
#    Put that number below.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Sonos (OPTIONAL — the `sonos` skill to control a speaker/soundbar). Your speaker's LAN IP
# (Sonos app → Settings → System → your product → About → IP Address). Discovery doesn't work
# from inside the container, so the skill targets this IP directly.
SONOS_HOST=

# ── File-based secrets (NOT env vars — listed here only so you know they exist) ──
# These live as files under data/secrets/ (git-ignored), read directly by their skill's CLI:
#   data/secrets/github_token            GitHub PAT (classic, scope `repo`) for the github-pages skill
#   data/secrets/google_oauth.json       Google OAuth token for gmail/drive/calendar/youtube
#   data/secrets/google_client_secret.json   Google OAuth client (see README → Google setup)
#   data/secrets/alan_api_key            Comma-Soft Alan API key (Bearer) for the `alan` skill (separate
#                                        from the model provider above — only the alan skill uses it)

# Advanced overrides (OPTIONAL). Listed for discoverability; uncomment only to override.
# CORE_MODEL=provider/model-id                              # override the scheduler model
#                                                           # (else pi's data/pi/settings.json default)
# CORE_MEMORY_DIR=/app/storage/memory                       # long-term memory store location
# SEARXNG_URL=http://searxng:8080                           # websearch backend
# GOOGLE_OAUTH_FILE=/app/secrets/google_oauth.json          # Google skills' shared OAuth token
