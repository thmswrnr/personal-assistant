# Copy to .env (which is git-ignored) and fill in as needed.
#
# Local-only use needs NOTHING here — the local llama.cpp model is configured in
# data/pi/models.json and requires no key.
#
# These are only needed if you switch pi to a commercial provider (see README →
# "Adding or switching a model"). Uncomment and set the ones you use. Confirm the exact
# variable name your provider expects via `docker exec core_harness pi --list-models`
# and the pi providers docs.

# Google Gemini
# GEMINI_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# Anthropic
# ANTHROPIC_API_KEY=

# Comma-Soft Alan (OPTIONAL — exposes Alan's OpenAI-compatible remote models as a pi provider;
# see data/pi/models.json "alan"). Same key as the data/secrets/alan_api_key file the `alan`
# skill uses — set it here too to run Core/subagents on Alan models, e.g.
#   docker exec core_harness pi --provider alan --model comma-soft/gemma4-31b-instant -p "hi"
# ALAN_API_KEY=

# SearXNG (websearch skill): secret key for the local, internal-only instance.
# Generate one with:  openssl rand -hex 32
SEARXNG_SECRET=

# Telegram (OPTIONAL — phone bridge + `notify` skill; Core runs fine without it).
# 1. Create a bot with @BotFather in Telegram, paste its token here.
# 2. Message your bot once, then start the bridge (docker compose --profile telegram up -d bot)
#    and read `docker logs core_bot` — it prints your chat id. Put it below and restart.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Sonos (OPTIONAL — the `sonos` skill to control a speaker/soundbar). Your speaker's LAN IP
# (Sonos app → Settings → System → your product → About → IP Address). Discovery doesn't work
# from inside the container, so the skill targets this IP directly.
SONOS_HOST=

# ── File-based secrets (NOT env vars — listed here only so you know they exist) ──
# These live as files under data/secrets/ (git-ignored), read directly by their skill's CLI:
#   data/secrets/github_token            GitHub PAT (classic, scope `repo`) for the github-pages skill
#   data/secrets/google_oauth.json       Google OAuth token for gmail/drive/calendar/youtube
#   data/secrets/google_client_secret.json   Google OAuth client (see README → Google setup)
#   data/secrets/alan_api_key            Comma-Soft Alan API key (Bearer) for the alan skill

# Advanced overrides (OPTIONAL — the defaults below are wired for the Docker network and rarely
# need changing). Listed for discoverability; uncomment only to override.
# CORE_MODEL=local/local-model                              # model id the bot/scheduler invoke
# LLM_URL=http://llm:8080/v1/chat/completions               # main model endpoint (bot: transcription)
# UTIL_MODEL_URL=http://llm-util:8080/v1/chat/completions   # util model (context-saver distill/compact)
# CORE_MEMORY_DIR=/app/storage/memory                       # long-term memory store location
# SEARXNG_URL=http://searxng:8080                           # websearch backend
# GOOGLE_OAUTH_FILE=/app/secrets/google_oauth.json          # Google skills' shared OAuth token
